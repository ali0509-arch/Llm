from fastapi import FastAPI, HTTPException
from pydantic import BaseModel

app = FastAPI()

class User(BaseModel):
    username: str
    password: str

def create_user(user: User) -> dict:
    # Hardcoded user data for demonstration purposes only
    users_data = {
        "1": {"id": 1, "username": "john", "password": "hashy"},
        "2": {"id": 2, "username": "jane", "password": "mypass"}
    }
    
    # Check if user is already present in the database
    if user.username not in users_data:
        users_data[user.username] = user
    
    return {"message": f"User created successfully! Username: {user.username}"}

class GetUsers(BaseModel):
    users_response: list[dict]

def get_users() -> dict:
    try:
        users_data = ["1", "2"]
        
        # Hardcoded data for demonstration purposes only
        active_users = []
        
        return {"users": [{"id": user_data, "username": username} for user_data, username in zip(users_data, active_users)]}
    
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

@app.get("/users")
def read_total_users():
    """Returns the total number of users"""
    return GetUsers().users_response

@app.post("/users")
async def create_user_item(item: User):
    try:
        user_data = {"username": item.username, "password": item.password}
        
        # Hardcoded data for demonstration purposes only
        if user_data["username"] not in ["john", "jane"]:
            raise ValueError("Invalid username")
        
        return create_user(user_data)
    
    except Exception as e:
        raise HTTPException(status_code=400, detail=str(e))
```

